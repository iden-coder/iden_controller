<launch>
  <arg name="map_yaml" default="$(find ucar_nav)/maps/6.3.1.yaml" />
  <arg name="goal_x" default="-1.48" />
  <arg name="goal_y" default="-0.45" />
  <arg name="goal_yaw" default="3.1415926" />
  <arg name="start_base" default="true" />
  <arg name="start_lidar" default="true" />
  <arg name="start_camera" default="true" />
  <arg name="qr_angular_speed" default="0.22" />
  <arg name="qr_decode_rate_hz" default="15.0" />
  <arg name="use_spark" default="true" />
  <arg name="spark_api_key" default="$(optenv SPARK_API_KEY)" />
  <arg name="spark_api_secret" default="$(optenv SPARK_API_SECRET)" />

  <node pkg="speech_command" type="cloud_asr_test2"
        name="cloud_asr_test2" output="screen"
        respawn="true" respawn_delay="0.8" />

  <node pkg="iden_controller" type="subtask1_real_order_fusion_route.py"
        name="subtask1_xunfei2026_voice_nav_qr_llm" output="screen">
    <param name="voice_topic" value="/factory/voice_raw_text" />
    <param name="qr_summary_topic" value="/qr_room_scan_results" />
    <param name="qr_item_topic" value="/qr_room_scan_item" />
    <param name="qr_scan_control_topic" value="/qr_room_scan_control" />
    <param name="tts_topic" value="/factory/tts_text" />
    <param name="result_topic" value="/factory/subtask1_result" />
    <param name="compat_target_topic" value="/factory/target_warehouses" />
    <param name="state_topic" value="/factory/task_state" />
    <param name="required_item_count" value="3" />
    <param name="streaming_qr_decision" value="false" />
    <param name="require_wake_before_order" value="true" />
    <param name="require_target_category" value="true" />
    <param name="rearm_asr_on_incomplete_voice" value="true" />
    <param name="asr_node_name" value="/cloud_asr_test2" />
    <param name="asr_rearm_delay_s" value="3.0" />
    <param name="auto_start_nav" value="false" />
    <param name="default_voice_text" value="" />
    <param name="nav_launch_pkg" value="iden_controller" />
    <param name="nav_launch_file" value="xunfei2026_first_stage_continuous_qr_v1.launch" />
    <param name="nav_roslaunch_args"
           value="map_yaml:=$(arg map_yaml) goal_x:=$(arg goal_x) goal_y:=$(arg goal_y) goal_yaw:=$(arg goal_yaw) start_base:=$(arg start_base) start_lidar:=$(arg start_lidar) start_camera:=$(arg start_camera) qr_angular_speed:=$(arg qr_angular_speed) qr_decode_rate_hz:=$(arg qr_decode_rate_hz)" />
    <param name="nav_start_delay_s" value="0.5" />
    <param name="use_spark" value="$(arg use_spark)" />
    <param name="require_spark_decision" value="true" />
    <param name="spark_api_key" value="$(arg spark_api_key)" />
    <param name="spark_api_secret" value="$(arg spark_api_secret)" />
    <param name="spark_timeout_s" value="18.0" />
    <param name="post_route_enabled" value="false" />
  </node>
</launch>
