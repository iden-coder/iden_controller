<launch>
  <!-- ===== 宽道定点巡航 (IdenPlannerV2, 锥桶场景优化) =====

       锥桶避障关键:
         - inflation_radius 从 0.10 降到 0.05 (锥桶细, 不需要大膨胀)
         - 轨迹采样范围更大 (角速度 ±2.0 rad/s)
         - 前向仿真更长 (1.5s, 可看到更远的锥桶)
         - 障碍物权重更高 (优先安全)
         - narrow_track_mode = false
         - 恢复用标准旋转+后退

       用法: roslaunch iden_controller cruise_navfn_v2_wide.launch
             rosrun iden_controller cruise_demo.py
  -->

  <include file="$(find iden_controller)/launch/my_base_driver_iden.launch" />
  <include file="$(find ydlidar)/launch/ydlidar.launch" />

  <node name="map_server" pkg="map_server" type="map_server"
        args="$(find ucar_nav)/maps/6.3.1.yaml" output="screen">
    <param name="frame_id" value="map" />
  </node>

  <include file="$(find ucar_nav)/launch/config/amcl/amcl_omni.launch" />

  <!-- ===== safety_monitor: 监听 move_base 输出, 安全过滤后发给机器人 ===== -->
  <node pkg="iden_controller" type="safety_monitor.py" name="safety_monitor" output="screen">
    <!-- 输入: 监听 move_base / cruise_demo 的原始速度 -->
    <param name="cmd_vel_in_topic" value="/cmd_vel_raw"/>
    <!-- 输出: 发布给底盘驱动 -->
    <param name="cmd_vel_out_topic" value="/cmd_vel"/>
    <param name="scan_topic" value="/scan"/>
    <param name="stop_zone" value="0.15"/>
    <param name="side_stop_zone" value="0.08"/>
    <param name="slowdown_zone" value="0.50"/>
    <param name="slowdown_ratio" value="0.55"/>
    <param name="monitor_front_angle_deg" value="45.0"/>
    <param name="monitor_side_angle_min" value="35.0"/>
    <param name="monitor_side_angle_max" value="65.0"/>
    <param name="min_angular_ratio" value="0.30"/>
    <param name="enabled" value="true"/>
  </node>

  <node pkg="move_base" type="move_base" respawn="false" name="move_base" output="screen">
    <remap from="cmd_vel" to="/cmd_vel_raw"/>
    <param name="base_global_planner" value="theta_star_ros/ThetaStarPlanner"/>
    <param name="base_local_planner" value="iden_planner_v2/IdenPlannerV2"/>

    <!-- 锥桶区: 高频重规划 -->
    <param name="planner_frequency" value="2.0"/>
    <param name="controller_frequency" value="10.0"/>

    <!-- Theta* 参数: 视线检测 + 任意角度路径 -->
    <param name="theta_star_ros/ThetaStarPlanner/w_euc_cost" value="1.0"/>
    <param name="theta_star_ros/ThetaStarPlanner/w_traversal_cost" value="0.1"/>
    <param name="theta_star_ros/ThetaStarPlanner/w_heuristic_cost" value="1.0"/>
    <param name="theta_star_ros/ThetaStarPlanner/allow_unknown" value="true"/>
    <param name="theta_star_ros/ThetaStarPlanner/max_non_obstacle" value="252"/>

    <!-- ===== IdenPlannerV2 — 锥桶场景参数 ===== -->

    <!-- PID: 锥桶场景需要更灵敏的角速度响应 -->
    <param name="iden_planner_v2/IdenPlannerV2/kp" value="4.0"/>
    <param name="iden_planner_v2/IdenPlannerV2/ki" value="0.02"/>
    <param name="iden_planner_v2/IdenPlannerV2/kd" value="0.10"/>
    <param name="iden_planner_v2/IdenPlannerV2/integral_limit" value="0.5"/>
    <param name="iden_planner_v2/IdenPlannerV2/lookahead_dist" value="0.30"/>
    <param name="iden_planner_v2/IdenPlannerV2/angle_power" value="1.0"/>
    <param name="iden_planner_v2/IdenPlannerV2/angle_full_speed_deg" value="0.0"/>
    <param name="iden_planner_v2/IdenPlannerV2/angle_zero_speed_deg" value="90.0"/>
    <param name="iden_planner_v2/IdenPlannerV2/enable_bidirectional" value="false"/>
    <param name="iden_planner_v2/IdenPlannerV2/long_lookahead" value="0.5"/>
    <param name="iden_planner_v2/IdenPlannerV2/reverse_vote_ratio" value="0.7"/>
    <param name="iden_planner_v2/IdenPlannerV2/reverse_confirm_frames" value="3"/>
    <!-- 锥桶区慢速: 0.4m/s, 给规划器足够时间反应 -->
    <param name="iden_planner_v2/IdenPlannerV2/max_linear_vel" value="0.35"/>
    <param name="iden_planner_v2/IdenPlannerV2/min_linear_vel" value="-0.15"/>
    <param name="iden_planner_v2/IdenPlannerV2/max_angular_vel" value="1.0"/>
    <param name="iden_planner_v2/IdenPlannerV2/linear_gain" value="3.0"/>
    <param name="iden_planner_v2/IdenPlannerV2/pose_dist_threshold" value="0.10"/>
    <param name="iden_planner_v2/IdenPlannerV2/pos_deadband" value="0.05"/>
    <param name="iden_planner_v2/IdenPlannerV2/yaw_deadband" value="0.05"/>
    <param name="iden_planner_v2/IdenPlannerV2/angle_adjust_gain" value="2.5"/>
    <param name="iden_planner_v2/IdenPlannerV2/slow_zone" value="0.2"/>
    <param name="iden_planner_v2/IdenPlannerV2/min_adjust_speed" value="0.12"/>
    <param name="iden_planner_v2/IdenPlannerV2/pose_tolerance" value="0.05"/>
    <param name="iden_planner_v2/IdenPlannerV2/pose_adjust_timeout" value="10.0"/>
    <param name="iden_planner_v2/IdenPlannerV2/pose_adjust_max_linear" value="0.10"/>
    <param name="iden_planner_v2/IdenPlannerV2/collision_check_count" value="15"/>
    <param name="iden_planner_v2/IdenPlannerV2/collision_cooldown_max" value="15"/>
    <param name="iden_planner_v2/IdenPlannerV2/collision_replan_max" value="3"/>
    <param name="iden_planner_v2/IdenPlannerV2/enable_visualization" value="false"/>
    <param name="iden_planner_v2/IdenPlannerV2/enable_costmap_pub" value="false"/>

    <!-- 前向碰撞检测: 看更远 -->
    <param name="iden_planner_v2/IdenPlannerV2/enable_forward_sim" value="true"/>
    <param name="iden_planner_v2/IdenPlannerV2/forward_sim_time" value="1.5"/>
    <param name="iden_planner_v2/IdenPlannerV2/forward_sim_step" value="0.05"/>

    <!-- 轨迹采样: 大范围搜索 (锥桶之间需要灵活穿行) -->
    <param name="iden_planner_v2/IdenPlannerV2/enable_traj_sampling" value="true"/>
    <param name="iden_planner_v2/IdenPlannerV2/traj_samples_vx" value="9"/>
    <param name="iden_planner_v2/IdenPlannerV2/traj_samples_wz" value="15"/>
    <param name="iden_planner_v2/IdenPlannerV2/traj_delta_vx" value="0.10"/>
    <!-- 角速度步长 0.25 → 总搜索范围 ±1.75 rad/s (能绕开侧面锥桶) -->
    <param name="iden_planner_v2/IdenPlannerV2/traj_delta_wz" value="0.25"/>
    <!-- 障碍物权重更高 -->
    <param name="iden_planner_v2/IdenPlannerV2/weight_obstacle" value="15.0"/>
    <param name="iden_planner_v2/IdenPlannerV2/weight_path" value="1.0"/>
    <param name="iden_planner_v2/IdenPlannerV2/weight_goal" value="0.5"/>

    <!-- 速度平滑 -->
    <param name="iden_planner_v2/IdenPlannerV2/enable_vel_smooth" value="true"/>
    <param name="iden_planner_v2/IdenPlannerV2/max_linear_accel" value="1.5"/>
    <param name="iden_planner_v2/IdenPlannerV2/max_linear_decel" value="2.5"/>
    <param name="iden_planner_v2/IdenPlannerV2/max_angular_accel" value="3.5"/>
    <param name="iden_planner_v2/IdenPlannerV2/max_angular_decel" value="3.5"/>

    <!-- 智能恢复: 宽道标准 -->
    <param name="iden_planner_v2/IdenPlannerV2/enable_smart_recovery" value="false"/>
    <param name="iden_planner_v2/IdenPlannerV2/recovery_rotation_speed" value="0.5"/>
    <param name="iden_planner_v2/IdenPlannerV2/recovery_rotation_angle" value="1.047"/>

    <!-- 关闭窄道约束 -->
    <param name="iden_planner_v2/IdenPlannerV2/narrow_track_mode" value="false"/>

    <!-- ═══ 分级速度策略 (锥桶避障核心) ═══ -->
    <param name="iden_planner_v2/IdenPlannerV2/enable_graded_speed" value="true"/>
    <param name="iden_planner_v2/IdenPlannerV2/danger_dist_far" value="0.80"/>
    <param name="iden_planner_v2/IdenPlannerV2/danger_dist_mid" value="0.40"/>
    <param name="iden_planner_v2/IdenPlannerV2/danger_dist_near" value="0.18"/>
    <param name="iden_planner_v2/IdenPlannerV2/speed_ratio_mid" value="0.50"/>
    <param name="iden_planner_v2/IdenPlannerV2/speed_ratio_near" value="0.20"/>

    <!-- ============================================
         锥桶场景代价地图: 减小膨胀半径
         锥桶直径 ~20cm, 膨胀 5cm → 代价地图中 ~30cm
         两个锥桶间距 > 35cm 即可通行
         ============================================ -->
    <rosparam ns="global_costmap" >
      footprint: [[0.171, -0.128], [0.171, 0.128],[-0.171, 0.128], [-0.171, -0.128]]
      obstacle_layer:
        enabled: true
        combination_method: 1
        track_unknown_space: true
        obstacle_range: 2.5
        raytrace_range: 3.0
        observation_sources: laser_scan_sensor
        laser_scan_sensor: {
          sensor_frame: laser_frame,
          data_type: LaserScan,
          topic: scan,
          marking: true,
          clearing: true,
          inf_is_valid: true
        }
      inflation_layer:
        enabled: true
        cost_scaling_factor: 10.0
        inflation_radius: 0.045
      static_layer:
        enabled: true
    </rosparam>

    <rosparam ns="local_costmap" >
      footprint: [[0.171, -0.128], [0.171, 0.128],[-0.171, 0.128], [-0.171, -0.128]]
      obstacle_layer:
        enabled: true
        combination_method: 1
        track_unknown_space: true
        obstacle_range: 2.5
        raytrace_range: 3.0
        observation_sources: laser_scan_sensor
        laser_scan_sensor: {
          sensor_frame: laser_frame,
          data_type: LaserScan,
          topic: scan,
          marking: true,
          clearing: true,
          inf_is_valid: true
        }
      inflation_layer:
        enabled: true
        cost_scaling_factor: 10.0
        inflation_radius: 0.045
      static_layer:
        enabled: true
    </rosparam>

    <rosparam file="$(find ucar_nav)/launch/config/move_base/local_costmap_params.yaml"
              command="load" />
    <rosparam file="$(find ucar_nav)/launch/config/move_base/global_costmap_params.yaml"
              command="load" />
  </node>
</launch>