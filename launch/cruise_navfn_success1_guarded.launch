<launch>
  <arg name="map_yaml" default="$(find ucar_nav)/maps/6.3.1.yaml" />
  <arg name="waypoints_yaml" default="$(find iden_controller)/config/navfn_success1_guarded_waypoints.yaml" />

  <include file="$(find iden_controller)/launch/my_base_driver_iden.launch" />
  <include file="$(find ydlidar)/launch/ydlidar.launch" />

  <node name="map_server" pkg="map_server" type="map_server"
        args="$(arg map_yaml)" output="screen" respawn="true">
    <param name="frame_id" value="map" />
  </node>

  <include file="$(find ucar_nav)/launch/config/amcl/amcl_omni.launch" />

  <group ns="navfn_success1_guarded">
    <param name="map_yaml" value="$(arg map_yaml)" />
    <param name="waypoints_yaml" value="$(arg waypoints_yaml)" />
    <param name="enable_preflight" value="true" />
    <param name="fail_goal_clearance" value="0.13" />
    <param name="warn_goal_clearance" value="0.20" />
    <param name="fail_force_clearance" value="0.18" />
    <param name="warn_segment_clearance" value="0.14" />
    <param name="strict_segment_fail" value="false" />
    <param name="keep_trying_all_goals" value="true" />
    <param name="allow_skip_after_recovery" value="false" />
    <param name="continue_after_failure" value="false" />
    <param name="amcl_fresh_timeout" value="60.0" />
    <param name="keep_trying_blocked_front" value="false" />
    <param name="publish_initial_pose_on_start" value="true" />
    <param name="enable_reverse_escape" value="false" />
    <param name="enable_target_turn" value="true" />
    <param name="target_turn_deadband_deg" value="8.0" />
    <param name="target_turn_max_deg" value="28.0" />
    <param name="target_turn_speed" value="0.18" />
    <param name="target_turn_min_clear" value="0.16" />
    <param name="enable_forward_unstick" value="true" />
    <param name="unstick_every_n_rounds" value="1" />
    <param name="unstick_forward_distance" value="0.10" />
    <param name="unstick_forward_speed" value="0.055" />
    <param name="unstick_step_distance" value="0.035" />
    <param name="unstick_forward_max_heading_error_deg" value="35.0" />
    <param name="unstick_min_front_clear" value="0.32" />
    <param name="unstick_min_side_clear" value="0.16" />
    <param name="unstick_min_rear_clear" value="0.22" />
    <rosparam file="$(arg waypoints_yaml)" command="load" />
  </group>

  <node pkg="iden_controller" type="safety_monitor_success1_guarded.py"
        name="safety_monitor" output="screen" respawn="true" respawn_delay="1.0">
    <param name="cmd_vel_in_topic" value="/cmd_vel_raw" />
    <param name="cmd_vel_out_topic" value="/cmd_vel" />
    <param name="scan_topic" value="/scan" />
    <param name="enabled" value="true" />
    <param name="swap_left_right" value="false" />
    <param name="stop_zone" value="0.16" />
    <param name="side_stop_zone" value="0.09" />
    <param name="slowdown_zone" value="0.46" />
    <param name="side_slowdown_zone" value="0.28" />
    <param name="slowdown_ratio" value="0.38" />
    <param name="monitor_front_angle_deg" value="38.0" />
    <param name="monitor_side_angle_min" value="35.0" />
    <param name="monitor_side_angle_max" value="75.0" />
    <param name="monitor_rear_angle_deg" value="35.0" />
    <param name="min_angular_ratio" value="0.20" />
    <param name="max_stop_angular" value="0.10" />
    <param name="allow_reverse" value="false" />
    <param name="max_escape_reverse" value="0.0" />
    <param name="rear_stop_zone" value="0.22" />
    <param name="rear_slowdown_zone" value="0.38" />
    <param name="scan_timeout" value="0.7" />
  </node>

  <node pkg="move_base" type="move_base" respawn="true" respawn_delay="1.0"
        name="move_base" output="screen">
    <remap from="cmd_vel" to="/cmd_vel_raw" />

    <param name="base_global_planner" value="navfn/NavfnROS" />
    <param name="base_local_planner" value="iden_planner/IdenPlanner" />
    <param name="planner_frequency" value="1.5" />
    <param name="controller_frequency" value="10.0" />
    <param name="planner_patience" value="4.0" />
    <param name="controller_patience" value="3.0" />
    <param name="oscillation_timeout" value="7.0" />
    <param name="oscillation_distance" value="0.12" />
    <param name="recovery_behavior_enabled" value="false" />
    <param name="clearing_rotation_allowed" value="false" />

    <param name="navfn/NavfnROS/allow_unknown" value="false" />
    <param name="navfn/NavfnROS/default_tolerance" value="0.24" />
    <param name="NavfnROS/allow_unknown" value="false" />
    <param name="NavfnROS/default_tolerance" value="0.24" />

    <param name="iden_planner/IdenPlanner/kp" value="3.2" />
    <param name="iden_planner/IdenPlanner/ki" value="0.02" />
    <param name="iden_planner/IdenPlanner/kd" value="0.07" />
    <param name="iden_planner/IdenPlanner/integral_limit" value="0.5" />
    <param name="iden_planner/IdenPlanner/lookahead_dist" value="0.34" />
    <param name="iden_planner/IdenPlanner/angle_power" value="1.5" />
    <param name="iden_planner/IdenPlanner/angle_full_speed_deg" value="0.0" />
    <param name="iden_planner/IdenPlanner/angle_zero_speed_deg" value="100.0" />
    <param name="iden_planner/IdenPlanner/enable_bidirectional" value="false" />
    <param name="iden_planner/IdenPlanner/long_lookahead" value="0.5" />
    <param name="iden_planner/IdenPlanner/reverse_vote_ratio" value="0.7" />
    <param name="iden_planner/IdenPlanner/reverse_confirm_frames" value="3" />
    <param name="iden_planner/IdenPlanner/max_linear_vel" value="0.42" />
    <param name="iden_planner/IdenPlanner/min_linear_vel" value="0.0" />
    <param name="iden_planner/IdenPlanner/max_angular_vel" value="1.05" />
    <param name="iden_planner/IdenPlanner/linear_gain" value="3.2" />
    <param name="iden_planner/IdenPlanner/pose_dist_threshold" value="0.12" />
    <param name="iden_planner/IdenPlanner/pos_deadband" value="0.06" />
    <param name="iden_planner/IdenPlanner/yaw_deadband" value="0.055" />
    <param name="iden_planner/IdenPlanner/angle_adjust_gain" value="1.6" />
    <param name="iden_planner/IdenPlanner/slow_zone" value="0.22" />
    <param name="iden_planner/IdenPlanner/min_adjust_speed" value="0.07" />
    <param name="iden_planner/IdenPlanner/pose_tolerance" value="0.050" />
    <param name="iden_planner/IdenPlanner/pose_adjust_timeout" value="5.0" />
    <param name="iden_planner/IdenPlanner/pose_adjust_max_linear" value="0.04" />
    <param name="iden_planner/IdenPlanner/collision_check_count" value="12" />
    <param name="iden_planner/IdenPlanner/collision_cooldown_max" value="16" />
    <param name="iden_planner/IdenPlanner/collision_replan_max" value="4" />
    <param name="iden_planner/IdenPlanner/enable_visualization" value="false" />
    <param name="iden_planner/IdenPlanner/enable_costmap_pub" value="false" />

    <rosparam ns="global_costmap">
      global_frame: map
      robot_base_frame: base_link
      update_frequency: 2.0
      publish_frequency: 1.0
      width: 640
      height: 640
      resolution: 0.03
      always_send_full_costmap: true
      static_map: true
      rolling_window: false
      transform_tolerance: 0.7
      track_unknown_space: true
      footprint: [[0.171, -0.128], [0.171, 0.128], [-0.171, 0.128], [-0.171, -0.128]]
      plugins:
        - {name: static_layer, type: "costmap_2d::StaticLayer"}
        - {name: obstacle_layer, type: "costmap_2d::ObstacleLayer"}
        - {name: inflation_layer, type: "costmap_2d::InflationLayer"}
      static_layer:
        enabled: true
      obstacle_layer:
        enabled: true
        combination_method: 1
        track_unknown_space: true
        obstacle_range: 2.0
        raytrace_range: 3.0
        observation_sources: laser_scan_sensor
        laser_scan_sensor: {sensor_frame: laser_frame, data_type: LaserScan, topic: scan, marking: true, clearing: true, inf_is_valid: true}
      inflation_layer:
        enabled: true
        cost_scaling_factor: 10.0
        inflation_radius: 0.10
    </rosparam>

    <rosparam ns="local_costmap">
      global_frame: odom
      robot_base_frame: base_link
      update_frequency: 8.0
      publish_frequency: 3.0
      always_send_full_costmap: true
      static_map: false
      rolling_window: true
      width: 2.8
      height: 2.8
      resolution: 0.04
      transform_tolerance: 0.7
      footprint: [[0.171, -0.128], [0.171, 0.128], [-0.171, 0.128], [-0.171, -0.128]]
      plugins:
        - {name: obstacle_layer, type: "costmap_2d::ObstacleLayer"}
        - {name: inflation_layer, type: "costmap_2d::InflationLayer"}
      obstacle_layer:
        enabled: true
        combination_method: 1
        track_unknown_space: true
        obstacle_range: 2.0
        raytrace_range: 3.0
        observation_sources: laser_scan_sensor
        laser_scan_sensor: {sensor_frame: laser_frame, data_type: LaserScan, topic: scan, marking: true, clearing: true, inf_is_valid: true}
      inflation_layer:
        enabled: true
        cost_scaling_factor: 10.0
        inflation_radius: 0.10
    </rosparam>
  </node>
</launch>
