<launch>
  <arg name="map_yaml" default="$(find ucar_nav)/maps/6.3.1.yaml" />

  <node pkg="iden_controller" type="persistent_hybrid_omni_action_server_v1.py"
        name="factory_room_persistent_first_graph" output="screen"
        respawn="false" required="true">
    <rosparam file="$(find iden_controller)/config/global_first_graph_nav_2249fcf.yaml"
              command="load" />
    <rosparam file="$(find iden_controller)/config/hybrid_omni_local_planner_v1.yaml"
              command="load" />
    <param name="map_yaml" value="$(arg map_yaml)" />
    <param name="action_name" value="/factory_room/move_base" />
    <param name="stale_first_nav_node" value="/global_first_graph_nav" />
    <param name="clear_service_name" value="/factory_room/move_base/clear_costmaps" />
    <param name="publish_initial_pose_on_start" value="false" />
    <param name="require_start_near_initial" value="false" />
    <param name="require_goal_yaw" value="true" />
    <param name="waypoint_enabled" value="false" />
    <param name="entry_waypoint_x" value="-0.85" />
    <param name="entry_waypoint_y" value="-1.41" />
    <param name="entry_goal_y_threshold" value="-1.75" />
    <param name="entry_target_x" value="-0.85" />
    <param name="entry_target_y" value="-1.90" />
    <param name="entry_target_match_radius_m" value="0.32" />
    <param name="entry_accept_y" value="-1.78" />
    <param name="indoor_trigger_y" value="-1.75" />
    <param name="cone_mapping_activation_y" value="-1.95" />
    <param name="indoor_cone_radius_m" value="0.15" />
    <param name="indoor_cone_exclusion_radius_m" value="0.20" />
    <param name="observation_accept_radius_m" value="0.26" />
    <param name="indoor_wall_front_stop_m" value="0.18" />
    <param name="indoor_wall_front_slow_m" value="0.32" />
    <param name="indoor_wall_side_stop_m" value="0.14" />
    <param name="indoor_wall_side_slow_m" value="0.22" />
    <param name="navigation_recovery_enabled" value="true" />
    <param name="navigation_recovery_stuck_s" value="7.0" />
    <param name="navigation_recovery_progress_m" value="0.040" />
    <param name="navigation_recovery_turn_speed" value="0.20" />
    <param name="navigation_recovery_turn_time_s" value="0.65" />
  </node>
</launch>
