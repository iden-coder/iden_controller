<launch>
  <arg name="map_yaml" default="$(find ucar_nav)/maps/6.3.1.yaml" />
  <arg name="start_safety_monitor" default="true" />

  <node if="$(arg start_safety_monitor)"
        pkg="iden_controller" type="global_first_safety_monitor_omni_v1.py"
        name="global_first_safety_monitor" output="screen"
        respawn="true" respawn_delay="1.0">
    <rosparam file="$(find iden_controller)/config/global_first_safety_parking_v8.yaml"
              command="load" />
    <param name="escape_enabled" value="false" />
    <param name="allow_reverse" value="false" />
    <param name="parking_passthrough" value="true" />
    <param name="indoor_trigger_y" value="-1.75" />
    <param name="indoor_front_critical_m" value="0.17" />
    <param name="indoor_front_stop_m" value="0.21" />
    <param name="indoor_front_slow_m" value="0.36" />
    <param name="indoor_side_critical_m" value="0.12" />
    <param name="indoor_side_stop_m" value="0.15" />
    <param name="indoor_side_avoid_m" value="0.18" />
    <param name="indoor_side_slow_m" value="0.23" />
    <param name="nav_max_forward_mps" value="0.30" />
    <param name="nav_max_lateral_mps" value="0.17" />
    <param name="nav_max_angular_rps" value="0.36" />
    <param name="parking_lateral_travel_limit_m" value="0.48" />
    <param name="parking_max_lateral_speed" value="0.10" />
  </node>

  <include file="$(find iden_controller)/launch/factory_room_hybrid_omni_action_v1.launch">
    <arg name="map_yaml" value="$(arg map_yaml)" />
  </include>

  <node pkg="iden_controller" type="run_factory_room_ocr_ros.sh"
        name="factory_room_ocr" output="screen" required="true">
    <param name="image_topic" value="/ucar_camera/image_raw" />
    <param name="result_topic" value="/factory_room/ocr_result" />
    <param name="control_topic" value="/factory_room/ocr_control" />
    <param name="process_rate_hz" value="4.0" />
    <param name="vote_window" value="10" />
    <param name="vote_need" value="5" />
    <param name="enabled_on_start" value="false" />
    <param name="publish_debug" value="true" />
  </node>

  <node pkg="iden_controller" type="factory_room_delivery_manager_center_only_v5.py"
        name="factory_room_delivery_manager" output="screen" required="true">
    <rosparam file="$(find iden_controller)/config/factory_room_mission_parking_v7.yaml"
              command="load" />
    <rosparam file="$(find iden_controller)/config/factory_room_center_only_full_v1.yaml"
              command="load" />
    <rosparam file="$(find iden_controller)/config/factory_room_center_only_full_v2.yaml"
              command="load" />
    <param name="navigate_start_pose" value="true" />
    <rosparam param="start_pose">[-0.85, -1.90, -1.5707963268]</rosparam>
    <param name="nav_stuck_timeout_s" value="30.0" />
    <param name="nav_progress_m" value="0.030" />
    <param name="workshop_scan_arc_deg" value="180.0" />
    <param name="center_lateral_near_min_speed" value="0.015" />
    <param name="center_lateral_timeout_s" value="32.0" />
    <param name="task_result_topic" value="/factory/subtask1_result" />
    <param name="tts_topic" value="/factory/tts_text" />
    <param name="image_topic" value="/ucar_camera/image_raw" />
    <param name="scan_topic" value="/scan" />
    <param name="pose_topic" value="/amcl_pose" />
    <param name="odom_topic" value="/odom" />
    <param name="cmd_vel_topic" value="/cmd_vel_raw" />
    <param name="parking_close_mode_topic" value="/factory/parking_close_mode" />
    <param name="move_base_action" value="/factory_room/move_base" />
    <param name="clear_costmaps_service" value="/factory_room/move_base/clear_costmaps" />
  </node>
</launch>
