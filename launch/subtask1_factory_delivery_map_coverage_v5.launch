<launch>
  <arg name="map_yaml" default="$(find ucar_nav)/maps/6.3.1.yaml" />
  <arg name="start_base" default="true" />
  <arg name="start_lidar" default="true" />
  <arg name="start_camera" default="true" />
  <arg name="start_map" default="true" />
  <arg name="start_amcl" default="true" />
  <arg name="start_safety_monitor" default="true" />

  <!-- Publish the static map at process start so the room planner does not
       spend its first ten seconds waiting for the voice-triggered nav child. -->
  <node if="$(arg start_map)" pkg="map_server" type="map_server"
        name="map_server" args="$(arg map_yaml)" output="screen"
        respawn="true">
    <param name="frame_id" value="map" />
  </node>

  <!-- QR-room navigation, voice order and QR inference are unchanged. -->
  <include file="$(find iden_controller)/launch/subtask1_real_factory_route_front_first_v2.launch">
    <arg name="map_yaml" value="$(arg map_yaml)" />
    <arg name="start_base" value="$(arg start_base)" />
    <arg name="start_lidar" value="$(arg start_lidar)" />
    <arg name="start_camera" value="$(arg start_camera)" />
    <arg name="start_map" value="false" />
    <arg name="start_amcl" value="$(arg start_amcl)" />
    <arg name="start_safety_monitor" value="false" />
  </include>

  <include file="$(find iden_controller)/launch/factory_room_delivery_runtime_map_coverage_v5.launch">
    <arg name="map_yaml" value="$(arg map_yaml)" />
    <arg name="start_safety_monitor" value="$(arg start_safety_monitor)" />
  </include>
</launch>
